import numpy as np

class GridMap:
    def __init__(self, size):
        self.size = size
        self.grid = np.zeros((size, size))

    def add_obstacle(self, x, y):
        if 0 <= x < self.size and 0 <= y < self.size:
            self.grid[x][y] = 1

    def is_free(self, x, y):
        return self.grid[x][y] == 0

    def display(self):
        print(self.grid)
